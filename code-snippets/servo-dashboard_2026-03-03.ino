}


/*
  Since ServoAngle00 is READ_WRITE variable, onServoAngle00Change() is
  executed every time a new value is received from IoT Cloud.
*/
void onServoAngle00Change()  
{
  // Add your code here to act upon ServoAngle00 change
  
  // https://www.handsontec.com/dataspecs/motor_fan/MG996R.pdf
  // "This high-torque standard servo can rotate approximately 120º"
  // -60 on the dashboard (slider left side) maps to: 120
  //   0 on the dashboard (middle of slider) maps to:  60
  //  60 on the dashboard (slider right side) maps to:  0
  servo.write( ( -1 ) * ( servo_angle_00 - 60 ) );
  
}

