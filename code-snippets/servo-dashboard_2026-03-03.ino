#include "thingProperties.h"

// https://github.com/arduino-libraries/Servo
#include <Servo.h>
#define SERVO_PIN 21
Servo servo;


void setup() 
{
  // Generated code
  Serial.begin(9600);
  delay(1500); 
  initProperties();
  ArduinoCloud.begin(ArduinoIoTPreferredConnection);
  setDebugMessageLevel(2);
  ArduinoCloud.printDebugInfo();

  servo_angle_00 = 0;
  servo.attach( SERVO_PIN );
  
}


void loop() 
{
  ArduinoCloud.update();
